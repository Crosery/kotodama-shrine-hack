# ============================================================
# LLM 配置：api/server.mjs 读取，前端不暴露 key
# ============================================================
# 任意 OpenAI 兼容接口的 key（DeepSeek / OpenRouter / 自建网关 / OpenAI 等）
# 三个变量名都识别，优先级 DEEPSEEK_API_KEY > OPENROUTER_API_KEY > OPENAI_API_KEY
OPENROUTER_API_KEY=your_api_key_here

# Upstream base URL（默认 OpenRouter 官方）
OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1

# 模型名（按 provider 文档替换）
OPENAI_COMPAT_MODEL=poolside/laguna-xs.2:free

# 本地 API 服务监听端口；前端 Vite dev 走 /api 代理到此
PORT=8787

# ============================================================
# 公网部署加固（local-first 留空即可，不影响本地开发）
# ============================================================
# 监听地址；local-first 默认 127.0.0.1（仅本机可访问）；公网部署改 0.0.0.0
HOST=127.0.0.1

# 公网部署必填，前端请求需带 Authorization: Bearer <PROXY_TOKEN>；留空 = 无鉴权（本地 OK）
PROXY_TOKEN=

# 模型白名单（逗号分隔）；留空 = 仅允许 OPENAI_COMPAT_MODEL，防止上游切换到昂贵模型
ALLOWED_MODELS=

# 单请求 body 上限（字节，默认 256KB）/ messages 上限 / 单条 content 上限
MAX_BODY_BYTES=262144
MAX_MESSAGES=50
MAX_CONTENT_LEN=8000

# per-IP 速率限制（每分钟）；公网部署建议前置 nginx/cloudflare 兜底
RATE_LIMIT_PER_MIN=30
